<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.gms.ads.AdView
            android:id="@+id/adViewTermsTop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:adSize="BANNER"
            app:adUnitId="ca-app-pub-2168080105757285/1575161576" />

        <TextView
            android:id="@+id/tvTermsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/terms_and_conditions_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="16dp"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvTermsContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/terms_part1"
            android:textSize="14sp"
            android:textColor="#333333"
            android:lineSpacingExtra="4dp" />

        <com.google.android.gms.ads.AdView
            android:id="@+id/adViewTermsMiddle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            app:adSize="BANNER"
            app:adUnitId="ca-app-pub-2168080105757285/8585392673" />

        <TextView
            android:id="@+id/tvTermsContent2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/terms_part2"
            android:textSize="14sp"
            android:textColor="#333333"
            android:lineSpacingExtra="4dp" />

        <com.google.android.gms.ads.AdView
            android:id="@+id/adViewTermsBottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:adSize="BANNER"
            app:adUnitId="ca-app-pub-2168080105757285/1575161576" />

    </LinearLayout>
</ScrollView>