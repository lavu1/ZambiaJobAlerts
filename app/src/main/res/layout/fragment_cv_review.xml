<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:ads="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/professional_cv"
            android:textSize="14sp"
            android:textColor="#000"
            android:lineSpacingExtra="4dp"
            android:padding="12dp"
            android:background="@drawable/rounded_corner"/>

        <com.google.android.gms.ads.AdView
            android:id="@+id/adViewCvReview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            ads:adSize="BANNER"
            ads:adUnitId="ca-app-pub-3940256099942544/6300978111" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#000000"
            android:textStyle="bold"
            android:text="@string/enter_email"/>
        <EditText
            android:id="@+id/emailInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:minHeight="48dp"
            android:autofillHints="emailAddress"
            android:hint="@string/enter_email"
            android:padding="12dp"
            android:background="@color/cardview_dark_background"
            android:textColor="#ffffff"
            android:inputType="textEmailAddress"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/enter_phone_number"
            android:textStyle="bold"
            android:textColor="#000000" />
        <EditText
            android:id="@+id/phoneInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:minHeight="48dp"
            android:autofillHints="phone"
            android:hint="@string/enter_phone_number"
            android:inputType="phone"
            android:padding="12dp"
            android:background="@color/cardview_dark_background"
            android:textColor="#ffffff"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/upload_cv_file_pdf_doc_docx"
            android:textStyle="bold"
            android:textColor="#000000" />
        <EditText
            android:id="@+id/fileInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:minHeight="48dp"
            android:autofillHints="file"
            android:hint="@string/upload_cv_file_pdf_doc_docx"
            android:focusable="false"
            android:inputType="none"
            android:padding="12dp"
            android:background="@color/cardview_dark_background"
            android:textColor="#ffffff"
            android:clickable="true"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/write_requested_changes_here"
            android:textStyle="bold"
            android:textColor="#000000" />
        <EditText
            android:id="@+id/changesInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:minHeight="100dp"
            android:autofillHints="profile"
            android:hint="@string/write_requested_changes_here"
            android:padding="12dp"
            android:background="@color/cardview_dark_background"
            android:textColor="#ffffff"
            android:gravity="top|start"
            android:inputType="textMultiLine"/>

        <Button
            android:id="@+id/submitButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:text="@string/submit_for_review"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/advertisement"
            android:textSize="10sp"
            android:textColor="#888888"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="4dp"/>

        <com.google.android.gms.ads.AdView
            android:id="@+id/adViewCvReviewBottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:layout_gravity="center_horizontal"
            ads:adSize="BANNER"
            ads:adUnitId="ca-app-pub-2168080105757285/8585392673" />

    </LinearLayout>
</ScrollView>

