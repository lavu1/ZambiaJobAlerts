<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:ads="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <com.google.android.gms.ads.AdView
            android:id="@+id/adViewCvWriteTop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            ads:adSize="BANNER"
            ads:adUnitId="ca-app-pub-2168080105757285/1575161576" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="@string/get_a_professional"
            android:textSize="14sp"
            android:textColor="#000"
            android:lineSpacingExtra="4dp"
            android:padding="12dp"
            android:background="@drawable/rounded_corner"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#000000"
            android:textStyle="bold"
            android:text="@string/full_name"/>
        <EditText
            android:id="@+id/nameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:minHeight="48dp"
            android:autofillHints="name"
            android:inputType="textPersonName"
            android:background="@color/cardview_dark_background"
            android:textColor="#ffffff"
            android:padding="12dp"
            android:hint="@string/full_name"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#000000"
            android:textStyle="bold"
            android:text="@string/enter_email"/>
        <EditText
            android:id="@+id/emailInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:minHeight="48dp"
            android:autofillHints="emailAddress"
            android:background="@color/cardview_dark_background"
            android:textColor="#ffffff"
            android:padding="12dp"
            android:hint="@string/enter_email"
            android:inputType="textEmailAddress"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#000000"
            android:textStyle="bold"
            android:text="@string/enter_phone_number"/>
        <EditText
            android:id="@+id/phoneInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:minHeight="48dp"
            android:autofillHints="phone"
            android:background="@color/cardview_dark_background"
            android:textColor="#ffffff"
            android:padding="12dp"
            android:hint="@string/enter_phone_number"
            android:inputType="phone"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#000000"
            android:textStyle="bold"
            android:text="@string/enter_education_background"/>
        <EditText
            android:id="@+id/educationInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:minHeight="100dp"
            android:gravity="top|start"
            android:autofillHints="profile"
            android:background="@color/cardview_dark_background"
            android:inputType="textMultiLine"
            android:textColor="#ffffff"
            android:padding="12dp"
            android:hint="@string/enter_education_background"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#000000"
            android:textStyle="bold"
            android:text="@string/enter_work_experience"/>
        <EditText
            android:id="@+id/workInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="100dp"
            android:gravity="top|start"
            android:autofillHints="profile"
            android:background="@color/cardview_dark_background"
            android:inputType="textMultiLine"
            android:textColor="#ffffff"
            android:padding="12dp"
            android:hint="@string/work_experience"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/advertisement"
            android:textSize="10sp"
            android:textColor="#888888"
            android:layout_marginTop="24dp"
            android:layout_gravity="center_horizontal"/>

        <com.google.android.gms.ads.AdView
            android:id="@+id/adViewCvWrite"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:layout_gravity="center_horizontal"
            ads:adSize="BANNER"
            ads:adUnitId="ca-app-pub-2168080105757285/8585392673" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#000000"
            android:textStyle="bold"
            android:text="@string/enter_skills"/>
        <EditText
            android:id="@+id/skillsInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:minHeight="80dp"
            android:gravity="top|start"
            android:autofillHints="text"
            android:background="@color/cardview_dark_background"
            android:textColor="#ffffff"
            android:padding="12dp"
            android:hint="@string/skills"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#000000"
            android:textStyle="bold"
            android:text="@string/enter_additional_information"/>
        <EditText
            android:id="@+id/addNotesInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:minHeight="80dp"
            android:gravity="top|start"
            android:autofillHints="profile"
            android:inputType="textMultiLine"
            android:background="@color/cardview_dark_background"
            android:textColor="#ffffff"
            android:padding="12dp"
            android:hint="@string/additional_notes"/>

        <Button
            android:id="@+id/submitButton"
            android:text="Submit CV Request"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:layout_marginBottom="20dp"/>

    </LinearLayout>
</ScrollView>
