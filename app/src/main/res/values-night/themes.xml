<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme (Light/Day). -->
    <style name="BlackTextSpinner" parent="Widget.AppCompat.Spinner">
        <item name="android:textColor">#000000</item>
    </style>
    <style name="Theme.ZambiaJobAlerts" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color (Navy). -->
        <item name="colorPrimary">#001F3F</item>
        <item name="colorPrimaryVariant">#000080</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <!-- Secondary brand color (Orange). -->
        <item name="colorSecondary">#FF851B</item>
        <item name="colorSecondaryVariant">#FF4500</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <!-- Backgrounds. -->
        <item name="android:colorBackground">#FFFFFF</item>
        <item name="colorSurface">#F5F5F5</item> <!-- Cards, surfaces. -->
        <item name="colorOnSurface">#001F3F</item> <!-- Text on surfaces. -->
        <!-- Status bar color. -->
        <item name="android:statusBarColor">#000080</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="Theme.ZambiaJobAlerts.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.ZambiaJobAlerts.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.ZambiaJobAlerts.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />
</resources>
